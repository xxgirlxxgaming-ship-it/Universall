----------------------------------------------------------------
-- GAME-SPECIFIC TARGET HANDLING (Flick + universal)
----------------------------------------------------------------
-- Try to support games like Flick where targets are not Players
-- NOTE: adjust these names if Flick uses different folders
local TARGET_FOLDERS = {"Targets", "Target", "Dummies", "Bots"}

local function getCustomTargets()
    local list = {}

    for _, folderName in ipairs(TARGET_FOLDERS) do
        local folder = workspace:FindFirstChild(folderName)
        if folder then
            for _, obj in ipairs(folder:GetDescendants()) do
                if obj:IsA("BasePart") then
                    table.insert(list, obj)
                end
            end
        end
    end

    return list
end

