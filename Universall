local _kA = {119, 105, 110}   -- 'w','i','n'
local _kB = {116, 101, 114}   -- 't','e','r'

local function _d(list)
    local s = {}
    for i = 1, #list do
        s[i] = string.char(list[i])
    end
    return table.concat(s)
end

local function _buildKey()
    return _d(_kA) .. _d(_kB)
end

