----------------------------------------------------------------
-- TARGETING HELPERS (PLAYERS)
----------------------------------------------------------------
local function getAimPart(char)
    if not char then return nil end

    local mode = aimPartMode

    if mode == "Head" then
        return char:FindFirstChild("Head")
    elseif mode == "Torso" then
        return char:FindFirstChild("HumanoidRootPart")
            or char:FindFirstChild("UpperTorso")
            or char:FindFirstChild("Torso")
    elseif mode == "Random" then
        local choices = {
            char:FindFirstChild("Head"),
            char:FindFirstChild("HumanoidRootPart"),
            char:FindFirstChild("UpperTorso"),
            char:FindFirstChild("Torso")
        }
        local valid = {}
        for _, p in ipairs(choices) do
            if p then table.insert(valid, p) end
        end
        if #valid > 0 then
            return valid[math.random(1, #valid)]
        end
    end

    return char:FindFirstChild("HumanoidRootPart")
end

local function isVisible(part)
    if not visibilityCheck then return true end
    if not part or not Camera then return false end

    local origin    = Camera.CFrame.Position
    local direction = part.Position - origin

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {player.Character}

    local result = workspace:Raycast(origin, direction, params)
    if not result then
        return true
    end

    return result.Instance and result.Instance:IsDescendantOf(part.Parent)
end

local function isValidPlayerTarget(plr)
    if plr == player then return false end
    local char = plr.Character
    if not char then return false end

    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end

    if teamCheck and player.Team and plr.Team and plr.Team == player.Team then
        return false
    end

    return true
end

----------------------------------------------------------------
-- UNIVERSAL TARGET COLLECTION (PLAYERS + FLICK TARGETS)
----------------------------------------------------------------
local function collectTargets()
    local candidates = {}
    local mousePos   = UserInputService:GetMouseLocation()

    -- 1) Regular players
    for _, plr in ipairs(Players:GetPlayers()) do
        if not isValidPlayerTarget(plr) then
            continue
        end

        local char = plr.Character
        local part = getAimPart(char)
        if not part then continue end

        table.insert(candidates, {
            kind = "Player",
            owner = plr,
            part  = part,
        })
    end

    -- 2) Custom Flick / target parts
    for _, part in ipairs(getCustomTargets()) do
        if part and part:IsA("BasePart") then
            -- If game uses custom health system, you could add extra checks here
            table.insert(candidates, {
                kind = "Custom",
                owner = nil,
                part  = part,
            })
        end
    end

    return candidates
end

local function getBestTarget()
    local bestPart  = nil
    local bestScore = math.huge

    local mousePos = UserInputService:GetMouseLocation()

    for _, data in ipairs(collectTargets()) do
        local part = data.part
        if not part then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen or screenPos.Z <= 0 then
            continue
        end

        local screen2D = Vector2.new(screenPos.X, screenPos.Y)
        local delta    = screen2D - mousePos
        local dist2D   = delta.Magnitude

        if useFOVCheck and dist2D > aimFOV then
            continue
        end

        if not isVisible(part) then
            continue
        end

        local dist3D = (part.Position - Camera.CFrame.Position).Magnitude
        local score  = 0

        if preferClosestToCrosshair then
            score = score + dist2D
        end
        if preferNearestDistance then
            score = score + dist3D * 0.1
        end

        if score < bestScore then
            bestScore = score
            bestPart  = part
        end
    end

    return bestPart
end

----------------------------------------------------------------
-- AIMBOT LOOP
----------------------------------------------------------------
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    fovCircle.Position = mousePos
    fovCircle.Radius   = aimFOV
    fovCircle.Visible  = aimEnabled

    if not aimEnabled then return end

    local shouldAim
    if aimAlwaysOn then
        shouldAim = true
    else
        shouldAim = aimbotActive
    end

    if not shouldAim then return end

    local targetPart = getBestTarget()
    if not targetPart then return end

    local camCF = Camera.CFrame
    local newCF = CFrame.new(camCF.Position, targetPart.Position)

    local alpha = math.clamp(aimSmooth, 0, 1)
    if alpha <= 0 then
        Camera.CFrame = newCF
    else
        Camera.CFrame = camCF:Lerp(newCF, alpha)
    end
end)

